# ⚠️ DO NOT COMMIT THIS FILE TO GIT WITH REAL VALUES!
# This is a template. Create the actual secret with:
#
# kubectl create secret generic SERVICE_NAME-secret \
#   --namespace=NAMESPACE \
#   --from-literal=username=myuser \
#   --from-literal=password=mypassword
#
# Or use SOPS encryption (see Phase 5 docs)

apiVersion: v1
kind: Secret
metadata:
  name: SERVICE_NAME-secret
  namespace: NAMESPACE
  labels:
    app: SERVICE_NAME
type: Opaque
stringData:
  # Use stringData for plain text (will be base64 encoded automatically)
  username: "REPLACE_WITH_USERNAME"
  password: "REPLACE_WITH_PASSWORD"
  api-key: "REPLACE_WITH_API_KEY"

# Or use data for base64-encoded values:
# data:
#   username: dXNlcm5hbWU=  # "username" in base64
#   password: cGFzc3dvcmQ=  # "password" in base64
